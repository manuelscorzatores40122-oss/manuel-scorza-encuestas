# ─────────────────────────────────────────────────────
#  PsicoEscolar — Servicio de Notificaciones por Email
#  Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────────────

# URL pública de la app (para los links en los mensajes)
APP_URL="https://tu-app.vercel.app"

# ── SMTP ──────────────────────────────────────────────
# Gmail: usa una "Contraseña de aplicación", no tu clave normal
#   Cuenta Google → Seguridad → Verificación en 2 pasos
#   → Contraseñas de aplicaciones → Correo / Otro dispositivo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="bienestar@scorzatorres.edu.pe"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="PsicoEscolar <bienestar@scorzatorres.edu.pe>"

# ── Intervalos de revisión (minutos) ─────────────────
INTERVALO_CREDENCIALES="5"
INTERVALO_ANUNCIOS="10"
INTERVALO_ENCUESTAS="10"
