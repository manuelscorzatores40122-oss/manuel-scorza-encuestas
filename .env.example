# PostgreSQL — Supabase, Neon, Railway o local
# Si usas Neon/Supabase pooler en desarrollo, agrega connection_limit y pool_timeout
# para evitar timeouts del pool de Prisma con Next.js dev:
# ?sslmode=require&connection_limit=3&pool_timeout=30
DATABASE_URL="postgresql://user:password@localhost:5432/psicoescolar?schema=public"

# JWT — generar con: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secret-largo-y-aleatorio-min-32-caracteres"

# URL pública (para producción)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Web Push — generar con: npx web-push generate-vapid-keys
VAPID_SUBJECT="mailto:bienestar@scorzatorres.edu.pe"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# (Opcional) SMTP para notificar apoderados — Resend, SendGrid, Gmail, etc.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="bienestar@scorzatorres.edu.pe"
